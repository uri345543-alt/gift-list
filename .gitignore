# Root .gitignore for Python backend + React frontend (JetBrains IDE)

# ---- OS / Editor ----
.DS_Store
Thumbs.db

# JetBrains IDE project files
.idea/
*.iml

# ---- Python / Backend ----
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
backend/.venv/

# Build & packaging
build/
dist/
.eggs/
*.egg-info/

# Test/Tool caches
.pytest_cache/
.mypy_cache/
.cache/
.tox/
.coverage
.coverage.*
htmlcov/

# Databases & local state
*.db
*.sqlite3
backend/app.db
app.db

# Env files (secrets)
.env
.env.*
.envrc
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Logs
logs/
*.log

# ---- Node / Frontend ----
frontend/node_modules/
frontend/.pnp/
.pnp.*
frontend/build/
frontend/dist/

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage (frontend)
coverage/
.nyc_output/

# ---- Misc ----
tmp/
temp/
